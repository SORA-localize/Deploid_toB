---
const nav = [
  { href: '/guide/decision-variables', label: 'Guide' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
const path = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="Deploid /toB — home">
      <span class="logo-mark">DEPLOID</span><span class="logo-sub">/toB</span>
    </a>
    <nav aria-label="Primary">
      <ul>
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={['nav-link', { current: path.startsWith(item.href) }]}
              >
                <span class="nav-num">//</span> {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--rule);
    background: var(--bg);
  }
  .header-inner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 2rem;
    padding-block: 1.25rem;
  }
  .logo {
    text-decoration: none;
    display: inline-flex;
    align-items: baseline;
    gap: 0.5ch;
    letter-spacing: 0.04em;
  }
  .logo:hover {
    color: var(--fg);
  }
  .logo-mark {
    font-weight: 800;
    font-size: 1.15rem;
  }
  .logo-sub {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--fg-muted);
  }
  nav ul {
    display: flex;
    gap: 1.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--fg);
  }
  .nav-num {
    color: var(--fg-muted);
    margin-right: 0.25ch;
  }
  .nav-link.current {
    color: var(--accent);
  }
  .nav-link:hover {
    color: var(--accent);
  }
  @media (max-width: 560px) {
    .header-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
    nav ul {
      gap: 1.25rem;
    }
  }
</style>
